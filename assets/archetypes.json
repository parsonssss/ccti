  "signature_stat_templates": [
    {"id": "convo_density", "value_by": "F_vs_I",
     "F": {"value": "1.8×", "label": "与 Claude 对话密度\\nvs 与同事"},
     "I": {"value": "3.2×", "label": "与 Claude 对话密度\\nvs 与同事"}},
    {"id": "next_freq", "value_by": "S_vs_M",
     "S": {"value": "1/8", "label": "每 8 条消息出现\\n一次「下一个」"},
     "M": {"value": "1/24", "label": "每 24 条消息出现\\n一次「下一个」"}},
    {"id": "wait_patience", "value_by": "P_vs_R",
     "P": {"value": "12 次", "label": "等 Claude 思考\\n超过 30 秒"},
     "R": {"value": "0 次", "label": "等 Claude 思考\\n超过 30 秒"}},
    {"id": "iter_speed", "value_by": "S_vs_M",
     "S": {"value": "7.4×", "label": "迭代速度\\nvs 普通用户"},
     "M": {"value": "1.6×", "label": "迭代速度\\nvs 普通用户"}},
    {"id": "prompt_len", "value_by": "T_vs_V",
     "T": {"value": "13 字", "label": "单条 prompt\\n中位长度"},
     "V": {"value": "210 字", "label": "单条 prompt\\n中位长度"}},
    {"id": "reply_interval", "value_by": "S_vs_M",
     "S": {"value": "3 秒", "label": "看完回复后\\n发下一条的间隔"},
     "M": {"value": "1.4 分", "label": "看完回复后\\n发下一条的间隔"}},
    {"id": "pleasantries", "value_by": "T_vs_V",
     "T": {"value": "0 句", "label": "说过「谢谢」\\n或「麻烦你」"},
     "V": {"value": "6 句", "label": "说过「谢谢」\\n或「麻烦你」"}},
    {"id": "imperative_ratio", "value_by": "T_vs_V",
     "T": {"value": "96%", "label": "命令句体占比\\n(不带「请/能否」)"},
     "V": {"value": "62%", "label": "陈述+提问句占比\\n(带 why/how)"}}
  ]
}

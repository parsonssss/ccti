{
  "version": "1.1",
  "axes": {
    "F_vs_I": {
      "label": "下场度",
      "F": {"label": "Field Commander", "desc": "亲自下场写实现"},
      "I": {"label": "Idea Person", "desc": "只下指令,不写实现"}
    },
    "T_vs_V": {
      "label": "沟通密度",
      "T": {"label": "Terse", "desc": "简短直球"},
      "V": {"label": "Verbose", "desc": "长上下文,带解释"}
    },
    "S_vs_M": {
      "label": "节奏",
      "S": {"label": "Sprint", "desc": "冲刺型"},
      "M": {"label": "Marathon", "desc": "长跑型,慢工出活"}
    },
    "P_vs_R": {
      "label": "验证倾向",
      "P": {"label": "Paranoid", "desc": "事事验证"},
      "R": {"label": "Reckless", "desc": "yolo 派"}
    }
  },

  "dimensions": [
    {"key": "task_clarity",         "name_cn": "任务表达清晰度", "name_en": "Task Clarity"},
    {"key": "product_thinking",     "name_cn": "产品思维",       "name_en": "Product Thinking"},
    {"key": "diagnostics",          "name_cn": "问题诊断能力",   "name_en": "Diagnostics"},
    {"key": "technical_decisions",  "name_cn": "技术决策",       "name_en": "Tech Decisions"},
    {"key": "iteration_cadence",    "name_cn": "迭代节奏",       "name_en": "Iteration Cadence"},
    {"key": "agent_collaboration",  "name_cn": "代理协作意识",   "name_en": "Agent Collab"},
    {"key": "context_provision",    "name_cn": "上下文提供",     "name_en": "Context Provision"},
    {"key": "engineering_discipline","name_cn": "工程规范意识",  "name_en": "Engineering Discipline"}
  ],

  "archetypes": {
    "FTSP": {
      "name_cn": "稽查官",
      "name_en": "THE INSPECTOR",
      "tagline": "每行 diff 都要审、不验证不放心",
      "tier": "S",
      "slogan": "不验证,不松手",
      "explanation": "你亲手敲代码,Claude 是副驾。短指令、快节奏,但每个 commit 前你都把 diff 翻一遍。<strong>「跑过测试了吗」</strong>是你出场最高的口头禅。",
      "accent_lines": ["$ 改这里", "$ git diff", "$ test ?", "$ 通过"]
    },
    "FTSR": {
      "name_cn": "Yolo 王",
      "name_en": "THE YOLO",
      "tagline": "不读 diff 直接 git push",
      "tier": "A",
      "slogan": "先 push 再说",
      "explanation": "你亲手写,跑得飞快,不爱验证。Claude 帮你打字,你只关心<strong>「跑得起来吗」</strong>。线上挂了再修 — 你信 hotfix 文化。",
      "accent_lines": ["$ 跑", "$ 下一个", "$ git push -f", "$ 改天再测"]
    },
    "FTMP": {
      "name_cn": "冷面铁匠",
      "name_en": "THE SMITH",
